# ============================================================
# Kinder Stick OS — 환경 변수
# 이 파일을 .env.local로 복사하고 실제 값을 채우세요.
# .env.local은 .gitignore에 들어 있으니 커밋되지 않습니다.
# ============================================================

# ---- Supabase ----
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Project Settings → API → anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiI...

# Project Settings → API → service_role (secret) key — 서버 사이드에서만!
# 절대 클라이언트 컴포넌트에서 import하지 마세요. 서버 컴포넌트/Route Handler/Edge Function 전용.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiI...

# ---- Anthropic Claude ----
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- (Phase 3+ — 나중에 채움) KPI 연동 ----
# STRIPE_SECRET_KEY=sk_live_...
# TOSS_SECRET_KEY=test_sk_...
# CHANNELTALK_ACCESS_KEY=...
# GA4_SERVICE_ACCOUNT_JSON_PATH=./secrets/ga4-sa.json

# ---- (Phase 4+) 외부 AI 핸드오프 ----
# MEETFLOW_API_BASE=https://api.meetflow.example
# MEETFLOW_API_KEY=...
# MEETFLOW_CALLBACK_HMAC_SECRET=hex_random_64_chars

# ---- (옵션) Notion 통합 — 채택된 SMART action을 Notion DB row로 발행 ----
# 미설정 시 mock 모드로 동작 (메타데이터만 저장, 외부 호출 없음)
# https://www.notion.so/my-integrations 에서 internal integration 생성 후 토큰 복사
# 데이터베이스에 다음 컬럼 필요: Title(title) / Status(select) / Owner(rich_text)
#                              / Deadline(date) / Source(rich_text) / Action ID(rich_text)
#                              / Domain(rich_text) / Verify Metric(rich_text)
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=...

# ---- (옵션) Slack 통합 — 채택된 action을 채널에 알림 ----
# 미설정 시 mock 모드. Incoming Webhook URL 사용:
# https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
